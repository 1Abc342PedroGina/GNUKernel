/*
 * linux/kernel/core_sched.c - LIH Core Scheduler
 * 
 * Scheduler híbrido que unifica:
 *   - EEVDF (Earliest Eligible Virtual Deadline First) - Fair scheduling
 *   - CFS (Completely Fair Scheduler) do Linux - Compatibility layer
 * 
 * Gerencia simultaneamente:
 *   - thread_t do GNU Mach (microkernel threads)
 *   - task_struct do Linux (Linux processes/threads)
 * 
 * Parte do projeto LIH (Linux Is Hybrid)
 * 
 * Licença: GPLv2
 */

